node_modules
dist
*.local
.DS_Store

# Playwright
test-results/
playwright-report/
blob-report/
playwright/.cache/

# Local SPX reference templates (kept on disk, not in the repo)
example_projects/

# Never commit API keys - copy .env.example to .env and fill it in locally.
.env

# Local MCP server config (e.g. project-scoped Supabase MCP) - points at a specific project,
# don't ship it in the open/self-hostable repo. Auth is handled separately via OAuth.
.mcp.json

# AI bench / comparison outputs (screenshots + generated code, regenerated on demand).
# The out-dir is the operator's choice, so the bench patterns are deliberately broad.
bench-*/
video-bench-out*/
compare-out*/

# The bench dev server's own output (scripts/dev-bench.mjs) - a local trace of how the
# server died, useful on this machine and meaningless anywhere else.
dev-bench.log

# Catalog sweep taste screenshots (scripts/l3-sweep.mjs <shots-dir> <category>; multi-MB
# PNGs, regenerated on demand - review them on disk, never commit them)
l3-shots/
shots-*/

# Local render outputs + manifest fixtures (multi-MB, regenerated on demand by
# scripts/make-render-manifest.mjs and the render dev loop)
.render-dev/

# Generated per-checkout by scripts/dev-port.mjs (postinstall): each worktree gets its own
# dev-server port, so these files must never be shared through git. dev-port.json is the
# published record of the port this checkout actually reserved (docs/DEV_PORTS.md).
.claude/launch.json
.claude/dev-port.json

# Locally installed third-party agent skills (npx skills add ...) - vendor content,
# reinstallable on demand, never committed. The skills this repo OWNS are re-included by
# name below: git cannot un-ignore a path inside an ignored DIRECTORY, so this ignores the
# directory's CONTENTS (/*) and lists the exceptions. Add a line when a first-party skill
# is added - otherwise it silently stays untracked.
.claude/skills/*
!.claude/skills/ograf-expert/
!.claude/skills/spx-html-template-expert/
!.claude/skills/video-quality-round/
.agents/
skills-lock.json

# Remotion deploy bundle (built by render-worker/bundle.mjs in the Vercel build step)
render-worker/bundle/

# Remotion Player host bundle (built by scripts/build-player-host.mjs into public/ on
# postinstall/build) - compiled Remotion code stays out of the AGPL repo, like the bundle above
public/player-host/

# Vercel CLI link pointer (project/org id - local only)
.vercel/

.vercel
.env*.local

# Generated bundled-font CSS for the render worker (from public/fonts)
render-worker/remotion/*.generated.ts
